# ── Warboard V2 — Environment Variables ───────────────────────────────────────
# Copy this file to .env for local development (never commit .env to git).
# On Railway, set these in Project → Variables.

# Flask secret key — generate a strong random value for production:
#   python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=replace-me-with-a-strong-random-secret

# Comma-separated list of origins allowed to connect via WebSocket.
# Update to your production domain before deploying.
CORS_ORIGINS=https://warboardv2.com,https://www.warboardv2.com

# Set to false in production (Railway will use gunicorn; this flag only
# affects the python app.py dev server).
DEBUG=false

# Port the server listens on.
# Railway injects $PORT automatically — you do not need to set this manually.
PORT=5001

# PostgreSQL connection string.
# Railway injects DATABASE_URL automatically when you add a Postgres service.
# Leave unset to use the local SQLite fallback (warboard.db).
# DATABASE_URL=postgresql://user:password@host:5432/dbname

# Optional: key required to call the /admin/cleanup endpoint in production.
# ADMIN_KEY=replace-me-with-a-random-admin-key
